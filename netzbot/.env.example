# .birdie App-Verbindung
BIRDIE_API_URL=https://birdie.example.com
BIRDIE_BOT_TOKEN=bot_xxx

# Poll-Intervall (ms), Default: 60000
# NETZBOT_POLL_MS=60000

# Portal-Zugangsdaten: NETZBOT_CREDS_<SLUG>=user|pass|portalUrl
# SLUG = Netzbetreiber-Name in UPPER_SNAKE_CASE (Leerzeichen → _, Umlaute → AE/OE/UE)
# Beispiel:
# NETZBOT_CREDS_MITNETZ_STROM=installer@example.com|geheim123|https://portal.mitnetz-strom.de
# NETZBOT_CREDS_BAYERNWERK=installer@example.com|geheim123|https://www.bayernwerk-netz.de
